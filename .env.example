# OpsHub web — dev env. The API is reached via the Vite proxy (/v1 → :3000).
VITE_API_BASE_URL=/v1

# Entra ID SSO — set both to enable the Microsoft redirect login flow.
# Without these the app falls back to the dev login form (dev-only bypass).
# Register a SPA app in Azure Portal and set the redirect URI to http://localhost:5173.
# VITE_ENTRA_TENANT_ID=<your-directory-tenant-id>
# VITE_ENTRA_CLIENT_ID=<your-application-client-id>
